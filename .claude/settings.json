{
  "permissions": {
    "allow": [
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go get:*)",
      "Bash(go mod tidy:*)",
      "Bash(bun run:*)",
      "Bash(bun install:*)",
      "Bash(bun add:*)",
      "Bash(bun dev:*)",
      "Bash(docker compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker exec:*)",
      "Bash(curl:*)",
      "Bash(git:*)",
      "Bash(make:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/tools/scripts/validate-build.sh\"",
            "timeout": 60,
            "statusMessage": "Validating build..."
          }
        ]
      }
    ]
  }
}
